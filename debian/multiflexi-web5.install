debian/tmp/composer.json                  usr/lib/multiflexi-web
debian/autoload.php			  usr/share/php/multiflexi-web
src/*.php                                 usr/share/multiflexi-web
src/favicon.ico                           usr/share/multiflexi-web
src/.htaccess                             usr/share/multiflexi-web
src/js/*.js                               usr/share/multiflexi-web/js
src/js/languages/*.js                     usr/share/multiflexi-web/js/languages/
src/assets/Buttons-1.5.6/js/*             usr/share/multiflexi-web/assets/Buttons-1.5.6/js/
src/assets/Buttons-1.5.6/css/*            usr/share/multiflexi-web/assets/Buttons-1.5.6/css/
src/assets/Buttons-1.5.6/swf/*            usr/share/multiflexi-web/assets/Buttons-1.5.6/swf/
src/images/*                              usr/share/multiflexi-web/images
src/css/*                                 usr/share/multiflexi-web/css
src/MultiFlexi/*                         usr/lib/multiflexi-web/MultiFlexi/

debian/conf/multiflexi.conf    		      etc/apache2/conf-available
debian/conf/multiflexi.service 		      etc/avahi/services

debian/com.vitexsoftware.multiflexi.metainfo.xml    usr/share/metainfo/
debian/com.vitexsoftware.multiflexi.desktop         usr/share/applications/
multiflexi-web.svg                 			    usr/share/icons/hicolor/scalable/apps/
i18n/cs_CZ/LC_MESSAGES/*.mo                	usr/share/locale/cs_CZ/LC_MESSAGES/
i18n/en_US/LC_MESSAGES/*.mo                	usr/share/locale/en_US/LC_MESSAGES/

doc/GDPR*.md                                usr/share/doc/multiflexi-web/
